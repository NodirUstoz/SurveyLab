# =============================================================================
# SurveyLab Environment Configuration
# =============================================================================

# Django
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
POSTGRES_DB=surveylab
POSTGRES_USER=surveylab
POSTGRES_PASSWORD=surveylab_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_secret
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/2

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@surveylab.io

# File Storage
MAX_UPLOAD_SIZE_MB=10
MEDIA_URL=/media/
STATIC_URL=/static/

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_TITLE=SurveyLab

# Sentry (optional)
SENTRY_DSN=

# Rate Limiting
THROTTLE_RATE_ANON=100/hour
THROTTLE_RATE_USER=1000/hour
